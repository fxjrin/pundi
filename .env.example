# Copy this file to .env.local and fill in real values.
# None of these need a VITE_ prefix: they are only read by backend Vercel
# Functions (api/**), never by frontend code, so they never end up in the
# browser bundle.

# Neon Postgres connection string, provisioned via the Vercel dashboard's
# Storage tab (Marketplace -> Neon). Vercel injects this automatically once
# linked; only needed here for local development.
DATABASE_URL=

# Secret used to sign/verify auth JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=

# Gemini API key for the AI receipt-scan feature (F18). Get one at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
